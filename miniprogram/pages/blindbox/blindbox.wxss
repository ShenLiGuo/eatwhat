.page{padding:32rpx;min-height:100vh}
.hero{text-align:center;margin-bottom:48rpx}
.hero-icon{font-size:120rpx;display:block}
.hero-icon.rolling{animation:shake .5s ease-in-out}
@keyframes shake{0%,100%{transform:rotate(0)}20%{transform:rotate(-12deg)}40%{transform:rotate(12deg)}60%{transform:rotate(-8deg)}80%{transform:rotate(8deg)}}
.hero-title{font-size:40rpx;font-weight:800;margin:16rpx 0 8rpx;color:#333}
.hero-desc{font-size:26rpx;color:#bbb}
.section{margin-bottom:36rpx}
.sec-title{font-size:28rpx;font-weight:600;margin-bottom:18rpx;color:#555}
.flavor-grid{display:flex;flex-wrap:wrap;gap:16rpx}
.flavor-chip{padding:14rpx 28rpx;border-radius:32rpx;font-size:26rpx;border:none;background:#fff;color:#888;box-shadow:0 2rpx 8rpx rgba(0,0,0,.04)}
.flavor-chip.active{background:linear-gradient(135deg,#FFF4EC,#FFE8D6);color:#E8590C;font-weight:600;box-shadow:0 4rpx 12rpx rgba(233,89,12,.15)}
.count-picker{display:flex;align-items:center;justify-content:center;gap:24rpx}
.cp-label{font-size:28rpx;color:#888}
.cp-btn{width:68rpx;height:68rpx;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:40rpx;background:#fff;font-weight:700;color:#555;box-shadow:0 3rpx 10rpx rgba(0,0,0,.06)}
.cp-btn:active{background:#f5f5f5}
.cp-num{font-size:60rpx;font-weight:800;color:#E8590C;min-width:56rpx;text-align:center}
.btn-roll{width:100%;height:96rpx;border-radius:48rpx;background:linear-gradient(135deg,#E8590C,#D9480F);color:#fff;font-size:36rpx;font-weight:700;border:none;line-height:96rpx;box-shadow:0 8rpx 24rpx rgba(233,89,12,.25);letter-spacing:4rpx}
.btn-roll[disabled]{opacity:.5}
.btn-roll:active{transform:scale(.96)}
.result{margin-top:48rpx;text-align:center}
.result-title{font-size:32rpx;font-weight:700;margin-bottom:24rpx}
.result-list{display:flex;flex-wrap:wrap;justify-content:center;gap:16rpx;margin-bottom:28rpx}
.result-item{display:flex;align-items:center;gap:8rpx;background:#FFF4EC;border:2rpx solid #E8590C;border-radius:16rpx;padding:12rpx 24rpx;font-size:28rpx;font-weight:600;color:#E8590C}
.res-emoji{font-size:36rpx}
.btn-add{width:auto;display:inline-block;padding:18rpx 52rpx;border-radius:40rpx;border:3rpx solid #E8590C;background:#fff;color:#E8590C;font-size:28rpx;font-weight:600;line-height:1;box-shadow:0 4rpx 12rpx rgba(233,89,12,.1)}
.btn-add:active{background:#FFF4EC}

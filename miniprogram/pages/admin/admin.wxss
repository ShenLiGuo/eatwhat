.page { padding: 32rpx; }
.lock { text-align: center; padding: 80rpx 40rpx; }
.lock-icon { font-size: 80rpx; display: block; margin-bottom: 24rpx; }
.lock-inp {
  width: 100%; height: 80rpx; border: 2rpx solid #eee; border-radius: 16rpx;
  text-align: center; font-size: 32rpx; margin-bottom: 24rpx;
}
.lock-btn {
  width: 100%; height: 80rpx; border-radius: 16rpx; background: #E8590C;
  color: #fff; font-size: 32rpx; font-weight: 600; line-height: 80rpx;
}
.lock-error { color: #F03E3E; font-size: 26rpx; margin-top: 16rpx; }
.panel-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24rpx; }
.panel-title { font-size: 34rpx; font-weight: 700; }
.btn-logout { color: #999 !important; background: none !important; }
.add-form { display: flex; gap: 16rpx; margin-bottom: 24rpx; }
.add-inp {
  flex: 1; height: 72rpx; border: 2rpx solid #eee; border-radius: 36rpx;
  padding: 0 24rpx; font-size: 28rpx;
}
.btn-add { height: 72rpx; background: #E8590C; color: #fff; line-height: 72rpx; border-radius: 36rpx; }
.stats { display: flex; gap: 12rpx; margin-bottom: 24rpx; }
.stat-item {
  flex: 1; text-align: center; background: #fff; border-radius: 12rpx;
  padding: 16rpx 8rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,.03);
}
.stat-num { font-size: 40rpx; font-weight: 800; color: #E8590C; display: block; }
.stat-label { font-size: 22rpx; color: #999; display: block; }
.dish-list { display: flex; flex-direction: column; gap: 12rpx; margin-bottom: 24rpx; max-height: 500rpx; overflow-y: auto; }
.dish-item {
  display: flex; align-items: center; gap: 12rpx; background: #fff;
  padding: 16rpx 16rpx; border-radius: 12rpx; font-size: 28rpx;
}
.item-emoji { font-size: 32rpx; flex-shrink: 0; }
.item-name { flex: 1; font-weight: 500; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.item-badge { font-size: 20rpx; padding: 2rpx 12rpx; border-radius: 12rpx; }
.item-badge.def { background: #f5f5f5; color: #bbb; }
.item-badge.custom { background: #FFF4EC; color: #E8590C; }
.item-cat { font-size: 20rpx; color: #bbb; }
.btn-del { background: #FEE !important; color: #F03E3E !important; border: none !important; font-size: 24rpx; min-width: 48rpx; }
.btn-reset {
  width: 100%; height: 72rpx; border: 2rpx dashed #ddd; border-radius: 16rpx;
  background: none; color: #999; font-size: 26rpx;
}

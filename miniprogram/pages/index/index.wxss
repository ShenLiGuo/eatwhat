page{background:#f5f5f5}
.page{padding-bottom:120rpx}
.search-bar{padding:16rpx 24rpx;background:#f5f5f5}
.search-inp{width:100%;height:68rpx;border-radius:34rpx;border:none;padding:0 32rpx;font-size:28rpx;background:#fff;box-sizing:border-box}
.cat-scroll{white-space:nowrap;padding:8rpx 24rpx 16rpx}
.cat-tab{display:inline-block;padding:10rpx 26rpx;border-radius:28rpx;font-size:26rpx;background:#fff;color:#888;margin-right:12rpx}
.cat-tab.active{background:#E8590C;color:#fff}
.filter-row{display:flex;gap:12rpx;padding:0 24rpx 16rpx}
.filter-chip{font-size:22rpx;padding:6rpx 16rpx;border-radius:16rpx;background:#fff;color:#999}
.filter-chip.active{background:#FFF4EC;color:#E8590C;font-weight:600}

.dish-list{padding:0 20rpx}
.dish-card{display:flex;background:#fff;border-radius:16rpx;margin-bottom:14rpx;overflow:hidden}
.dish-img-wrap{width:200rpx;height:160rpx;flex-shrink:0;position:relative;background:#f0f0f0}
.dish-img{width:200rpx;height:160rpx}
.dish-img-fb{position:absolute;top:0;left:0;width:200rpx;height:160rpx;display:flex;align-items:center;justify-content:center;font-size:56rpx}
.dish-info{flex:1;padding:16rpx 20rpx;display:flex;flex-direction:column;justify-content:center;min-width:0}
.dish-name{font-size:30rpx;font-weight:700;margin-bottom:6rpx;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.dish-meta{display:flex;gap:8rpx;margin-bottom:8rpx}
.tag{font-size:20rpx;padding:2rpx 10rpx;border-radius:6rpx}
.cs-tag{background:#FFF0E6;color:#D9480F}
.re-tag.re-good{background:#E8F5E9;color:#2E7D32}
.re-tag.re-fresh{background:#FFF3E0;color:#E65100}
.dish-foot{display:flex;align-items:center;justify-content:space-between}
.flavor-text{font-size:22rpx;color:#bbb}
.qty-ctrl{display:flex;align-items:center;gap:8rpx}
.qty-btn{width:44rpx;height:44rpx;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:30rpx;font-weight:700}
.qty-btn.minus{background:#f0f0f0;color:#888}
.qty-btn.plus{background:#E8590C;color:#fff}
.qty-num{font-size:28rpx;font-weight:700;color:#E8590C;min-width:32rpx;text-align:center}
.empty{text-align:center;padding:80rpx 0;color:#ccc;font-size:28rpx}

.cart-bar{position:fixed;bottom:0;left:0;right:0;z-index:50;background:#fff;display:flex;align-items:center;padding:16rpx 24rpx;padding-bottom:calc(16rpx + env(safe-area-inset-bottom));box-shadow:0 -2rpx 12rpx rgba(0,0,0,.06)}
.cart-icon{font-size:48rpx;margin-right:16rpx}
.cart-info{flex:1}
.cart-title{font-size:28rpx;font-weight:600}
.cart-badge{background:#E8590C;color:#fff;font-size:24rpx;font-weight:700;min-width:44rpx;height:44rpx;border-radius:22rpx;display:flex;align-items:center;justify-content:center;padding:0 8rpx}

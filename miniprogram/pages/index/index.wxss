page{background:#f5f5f5}
.page{padding-bottom:140rpx}
.search-bar{padding:20rpx 24rpx;background:#f5f5f5}
.search-inp{width:100%;height:72rpx;border-radius:36rpx;border:none;padding:0 36rpx;font-size:28rpx;background:#fff;box-shadow:0 2rpx 8rpx rgba(0,0,0,.04);box-sizing:border-box}

/* Category tabs */
.cat-scroll{white-space:nowrap;padding:8rpx 24rpx 20rpx}
.cat-tab{display:inline-block;padding:12rpx 28rpx;border-radius:28rpx;font-size:26rpx;background:#fff;color:#888;margin-right:14rpx;box-shadow:0 2rpx 6rpx rgba(0,0,0,.03);transition:all .2s}
.cat-tab.active{background:linear-gradient(135deg,#E8590C,#D9480F);color:#fff;box-shadow:0 4rpx 12rpx rgba(233,89,12,.3)}

/* Filter row */
.filter-row{display:flex;gap:12rpx;padding:0 24rpx 20rpx}
.filter-chip{padding:8rpx 20rpx;border-radius:20rpx;font-size:22rpx;background:#fff;color:#999;box-shadow:0 1rpx 4rpx rgba(0,0,0,.03)}
.filter-chip.active{background:#FFF4EC;color:#E8590C;font-weight:600}

/* Dish cards */
.dish-list{padding:0 20rpx}
.dish-card{display:flex;background:#fff;border-radius:20rpx;margin-bottom:16rpx;overflow:hidden;box-shadow:0 4rpx 16rpx rgba(0,0,0,.05)}
.dish-img-wrap{width:200rpx;height:170rpx;flex-shrink:0;position:relative;background:#f5f5f5}
.dish-img{width:200rpx;height:170rpx;border-radius:0}
.dish-img-fb{position:absolute;top:0;left:0;width:200rpx;height:170rpx;display:flex;align-items:center;justify-content:center;font-size:60rpx}
.dish-info{flex:1;padding:18rpx 22rpx;display:flex;flex-direction:column;justify-content:center;min-width:0}
.dish-name{font-size:32rpx;font-weight:700;margin-bottom:8rpx;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.dish-meta{display:flex;gap:8rpx;margin-bottom:10rpx}
.tag{padding:4rpx 12rpx;border-radius:6rpx;font-size:20rpx}
.cs-tag{background:#FFF0E6;color:#D9480F}
.re-tag.re-good{background:#E8F5E9;color:#2E7D32}
.re-tag.re-fresh{background:#FFF3E0;color:#E65100}
.dish-foot{display:flex;align-items:center;justify-content:space-between}
.flavor-text{font-size:22rpx;color:#ccc}
.qty-ctrl{display:flex;align-items:center;gap:10rpx}
.qty-btn{width:48rpx;height:48rpx;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:32rpx;font-weight:700}
.qty-btn.minus{background:#f5f5f5;color:#999}
.qty-btn.plus{background:linear-gradient(135deg,#E8590C,#F0803A);color:#fff;box-shadow:0 3rpx 8rpx rgba(233,89,12,.25)}
.qty-btn:active{transform:scale(.9)}
.qty-num{font-size:30rpx;font-weight:700;color:#E8590C;min-width:36rpx;text-align:center}
.empty{text-align:center;padding:100rpx 0;color:#ccc;font-size:28rpx}

/* Cart bar */
.cart-bar{position:fixed;bottom:100rpx;left:0;right:0;z-index:50;background:#fff;display:flex;align-items:center;padding:18rpx 28rpx;padding-bottom:18rpx;box-shadow:0 -4rpx 20rpx rgba(0,0,0,.08)}
.cart-icon{font-size:52rpx;margin-right:18rpx}
.cart-info{flex:1}
.cart-title{font-size:30rpx;font-weight:700;color:#333}
.cart-badge{background:linear-gradient(135deg,#E8590C,#F0803A);color:#fff;font-size:24rpx;font-weight:700;min-width:48rpx;height:48rpx;border-radius:24rpx;display:flex;align-items:center;justify-content:center;padding:0 10rpx;box-shadow:0 3rpx 8rpx rgba(233,89,12,.3)}

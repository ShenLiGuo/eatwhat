.page { padding-bottom: 120rpx; }
.search-bar { padding: 16rpx 24rpx; }
.search-inp {
  width: 100%; height: 68rpx; border-radius: 34rpx; border: 2rpx solid #eee;
  padding: 0 32rpx; font-size: 28rpx; background: #fff;
}
.cat-scroll { white-space: nowrap; padding: 8rpx 24rpx 16rpx; }
.cat-tab {
  display: inline-block; padding: 12rpx 28rpx; border-radius: 32rpx;
  font-size: 26rpx; background: #fff; color: #888; margin-right: 12rpx;
  border: 2rpx solid #f0f0f0;
}
.cat-tab.active { background: #E8590C; color: #fff; border-color: #E8590C; }
.filter-row { display: flex; align-items: center; gap: 10rpx; padding: 0 24rpx 16rpx; }
.filter-label { font-size: 24rpx; color: #999; flex-shrink: 0; }
.filter-chip {
  font-size: 22rpx; padding: 6rpx 16rpx; border-radius: 20rpx;
  border: 2rpx solid #eee; background: #fff; color: #999;
}
.filter-chip.active { background: #FFF4EC; border-color: #E8590C; color: #E8590C; }

.dish-list { padding: 0 24rpx; }
.dish-card {
  display: flex; background: #fff; border-radius: 16rpx; margin-bottom: 16rpx;
  overflow: hidden; box-shadow: 0 2rpx 12rpx rgba(0,0,0,.04);
}
.dish-img { width: 180rpx; height: 180rpx; flex-shrink: 0; background: #f5f5f5; }
.dish-info { flex: 1; padding: 16rpx 20rpx; display: flex; flex-direction: column; justify-content: center; }
.dish-name { font-size: 30rpx; font-weight: 700; margin-bottom: 6rpx; }
.dish-tags { display: flex; flex-wrap: wrap; gap: 6rpx; margin-bottom: 8rpx; }
.tag {
  font-size: 20rpx; padding: 2rpx 10rpx; border-radius: 8rpx;
  background: #f5f5f5; color: #999;
}
.cs-tag { background: #FFF0E6; color: #D9480F; }
.dish-foot { display: flex; align-items: center; justify-content: space-between; }
.reheat-tag { font-size: 22rpx; color: #888; }
.qty-ctrl { display: flex; align-items: center; gap: 8rpx; }
.qty-btn {
  width: 44rpx; height: 44rpx; border-radius: 50%; display: flex; align-items: center;
  justify-content: center; font-size: 32rpx; font-weight: 700;
}
.qty-btn.minus { background: #f0f0f0; color: #888; }
.qty-btn.plus { background: #E8590C; color: #fff; }
.qty-num { font-size: 28rpx; font-weight: 700; color: #E8590C; min-width: 32rpx; text-align: center; }

.empty { text-align: center; padding: 80rpx 0; color: #ccc; font-size: 28rpx; }

/* Cart bar */
.cart-bar {
  position: fixed; bottom: 100rpx; left: 0; right: 0; z-index: 50;
  background: #fff; display: flex; align-items: center; padding: 16rpx 24rpx;
  border-top: 2rpx solid #f0f0f0; box-shadow: 0 -4rpx 16rpx rgba(0,0,0,.04);
}
.cart-icon { font-size: 44rpx; margin-right: 16rpx; }
.cart-icon.has-items { color: #E8590C; }
.cart-info { flex: 1; }
.cart-title { font-size: 28rpx; font-weight: 600; display: block; }
.cart-hint { font-size: 22rpx; color: #999; display: block; }
.cart-badge {
  background: #E8590C; color: #fff; font-size: 22rpx; font-weight: 700;
  min-width: 40rpx; height: 40rpx; border-radius: 20rpx; display: flex;
  align-items: center; justify-content: center;
}
